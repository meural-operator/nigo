# =============================================================================
# TurboNIGO — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so

# --- Datasets (too large for git) ---
datasets/
*.h5
*.hdf5
*.nc

# --- Results & Checkpoints ---
results/
results_ks/
results_sw/
figures/
*.pth
*.pt

# --- Analysis & Exports ---
Shallow_Water_Analysis_Report.pdf
export_pdf.py

# --- Environment ---
.env
*.log
.vscode/
.idea/

# --- OS ---
Thumbs.db
.DS_Store
desktop.ini

# --- Temp files ---
*.txt
/tmp/
*.tmp

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Conda ---
*.conda

# --- ICML Specific / Temp ---
test_*.py
_*.py
*.diff
*.gif
run_metrics.py

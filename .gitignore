# =============================================================================
# TurboNIGO — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so

# --- Datasets (too large for git) ---
datasets/
*.h5
*.hdf5
*.nc

# --- Results & Checkpoints ---
results/
results_ks/
results_sw/
*.pth
*.pt

# --- Analysis & Exports ---
Shallow_Water_Analysis_Report.pdf
export_pdf.py
sw_full_comparison_results/
scripts/full_comparison_sw.py

# --- Environment ---
.env
*.log
.vscode/
.idea/

# --- OS ---
Thumbs.db
.DS_Store
desktop.ini

# --- Temp files ---
*.txt
/tmp/
*.tmp

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Conda ---
*.conda

# --- ICML Specific / Temp ---
test_*.py
_*.py
*.diff
*.gif
run_metrics.py
additional_material/

# --- Comparison & Analysis Results ---
full_comparison_results/

# --- Interpretability (local analysis, not part of core framework) ---
interpretability/

# --- Test suite (meta-analysis, not part of core framework) ---
tests/

# --- Analysis/meta scripts ---
scripts/analyze_*.py
scripts/generate_*.py
scripts/evaluate_ablations_*.py
scripts/run_ablations_*.py
scripts/visualize_*_dataset.py
scripts/full_comparison*.py
scripts/train_stable_nigo.py

# --- Deprecated files ---
*_deprecated*
